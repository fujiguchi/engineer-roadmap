      padding: 4px 10px; border-radius: 5px; margin-bottom: 10px;
    }
    .today-week { font-size: 11px; color: var(--muted); letter-spacing: 1px; margin-bottom: 4px; }
    .today-title { font-size: 18px; font-weight: 800; line-height: 1.45; margin-bottom: 8px; text-wrap: balance; }
    .today-desc { font-size: 13px; color: var(--muted); line-height: 1.7; margin-bottom: 16px; }

    /* ── Timer ── */
    .timer {
      background: var(--bg); border: 1px solid var(--line); border-radius: 12px;
      padding: 16px; text-align: center; margin-bottom: 14px;
    }
    .timer-digits {
      font-family: var(--mono); font-size: 44px; font-weight: 700;
      font-variant-numeric: tabular-nums; letter-spacing: 2px; line-height: 1.1;
    }
    .timer.running .timer-digits { color: var(--accent-soft); }
    .timer.finished .timer-digits { color: var(--accent); }
    .timer-track { height: 5px; background: rgba(255,255,255,0.08); border-radius: 3px; overflow: hidden; margin: 12px 0; }
    .timer-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--accent), var(--accent-soft)); border-radius: 3px; transition: width 1s linear; }
    .timer-msg { font-size: 12px; color: var(--muted); min-height: 18px; }
    .timer.finished .timer-msg { color: var(--accent-soft); font-weight: 700; }
    .timer-btns { display: flex; gap: 8px; justify-content: center; margin-top: 10px; }

    /* ── Buttons ── */
    button {
      font-family: inherit; cursor: pointer; border: none; border-radius: 10px;
      font-weight: 800; transition: opacity 0.15s ease, transform 0.05s ease;
    }
    button:active { transform: scale(0.98); }
    button:focus-visible { outline: 2px solid var(--accent-soft); outline-offset: 2px; }
    .btn-primary {
      width: 100%; padding: 14px; font-size: 15px;
      background: linear-gradient(135deg, var(--accent), #0ea5b5); color: #06202a;
    }
    .btn-primary:disabled { opacity: 0.35; cursor: default; }
    .btn-ghost {
      padding: 9px 18px; font-size: 13px; background: var(--surface2);
      color: var(--text); border: 1px solid var(--line);
    }
    .btn-danger-ghost {
      padding: 8px 16px; font-size: 12px; background: none;
      color: var(--danger); border: 1px solid rgba(255,122,110,0.35);
    }

    /* ── Note ── */
    .note-field { margin-top: 14px; }
    .note-field label { display: block; font-size: 11px; color: var(--muted); letter-spacing: 1px; margin-bottom: 6px; }
    .note-field textarea {
      width: 100%; min-height: 64px; resize: vertical;
      background: var(--bg); color: var(--text);
      border: 1px solid var(--line); border-radius: 10px;
      padding: 10px 12px; font-family: inherit; font-size: 13px; line-height: 1.6;
    }
    .note-field textarea:focus { outline: none; border-color: rgba(24,197,212,0.5); }

    /* ── Map ── */
    .map-card {
      background: var(--surface); border: 1px solid var(--line);
      border-radius: 16px; padding: 18px 20px; margin-bottom: 14px;
    }
    .map-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 14px; }
    .map-head h2 { font-size: 13px; font-weight: 800; letter-spacing: 1px; }
    .map-head .hint { font-size: 10px; color: var(--dim); }
    .map-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; }
    .cell {
      aspect-ratio: 1; border-radius: 10px; border: 1px solid var(--line);
      background: var(--bg); color: var(--dim);
      font-size: 12px; font-weight: 800; font-variant-numeric: tabular-nums;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; padding: 0;
    }
    .cell.done { background: rgba(24,197,212,0.18); border-color: rgba(24,197,212,0.45); color: var(--accent-soft); }
    .cell.current { border-color: var(--accent); color: var(--text); box-shadow: 0 0 0 1px var(--accent); }
    .cell.selected { background: var(--accent); border-color: var(--accent); color: #06202a; }
    .map-legend { display: flex; gap: 14px; margin-top: 12px; font-size: 10px; color: var(--muted); }
    .map-legend span { display: flex; align-items: center; gap: 5px; }
    .lg { width: 10px; height: 10px; border-radius: 3px; display: inline-block; }
    .lg.done { background: rgba(24,197,212,0.18); border: 1px solid rgba(24,197,212,0.45); }
    .lg.current { background: var(--bg); border: 1px solid var(--accent); }
    .lg.todo { background: var(--bg); border: 1px solid var(--line); }

    /* ── Detail (selected day) ── */
    .detail {
      background: var(--surface); border: 1px solid var(--line);
      border-radius: 16px; padding: 20px; margin-bottom: 14px;
    }
    .detail .status { font-size: 11px; font-weight: 800; letter-spacing: 1px; margin-bottom: 8px; }
    .detail .status.is-done { color: var(--accent-soft); }
    .detail .status.is-todo { color: var(--muted); }
    .detail .today-title { font-size: 16px; }
    .detail .btn-row { margin-top: 14px; }

    /* ── Weeks overview ── */
    .weeks {
      background: var(--surface); border: 1px solid var(--line);
      border-radius: 16px; padding: 18px 20px; margin-bottom: 14px;
    }
    .weeks h2 { font-size: 13px; font-weight: 800; letter-spacing: 1px; margin-bottom: 12px; }
    .week-row { display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid var(--line); }
    .week-row:last-child { border-bottom: none; }
    .week-row .wl { font-size: 13px; }
    .week-row .wl .wn { font-size: 10px; color: var(--accent); font-weight: 800; letter-spacing: 1px; display: block; }
    .week-row .wc { font-size: 12px; font-weight: 800; color: var(--muted); font-variant-numeric: tabular-nums; }

    /* ── Complete banner ── */
    .complete-banner {
      background: linear-gradient(135deg, rgba(24,197,212,0.18), rgba(95,224,234,0.08));
      border: 1px solid rgba(24,197,212,0.45);
      border-radius: 16px; padding: 22px; text-align: center; margin-bottom: 14px;
    }
    .complete-banner .big { font-size: 22px; font-weight: 800; color: var(--accent-soft); margin-bottom: 6px; }
    .complete-banner p { font-size: 13px; color: var(--text); }
    .complete-banner a { color: var(--accent-soft); font-weight: 800; }

    /* ── Footer ── */
    .app-foot { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }
    .app-foot a { font-size: 12px; color: var(--muted); text-decoration: none; }
    .app-foot a:hover { color: var(--accent-soft); }

    .hidden { display: none !important; }

    @media (prefers-reduced-motion: reduce) {
      * { transition: none !important; animation: none !important; }
    }
    @media (max-width: 380px) {
      .hero { flex-direction: column; }
      .timer-digits { font-size: 36px; }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="app-head">
      <div class="app-title">30<span class="x">×</span>30</div>
      <div class="app-sub">1日30分 × 30日</div>
    </div>

    <!-- Hero -->
    <div class="hero">
      <div class="ring-wrap">
        <svg width="108" height="108" viewBox="0 0 108 108" aria-hidden="true">
          <circle class="ring-bg" cx="54" cy="54" r="47" fill="none" stroke-width="9"></circle>
          <circle class="ring-fg" id="ring" cx="54" cy="54" r="47" fill="none" stroke-width="9"
                  stroke-linecap="round" stroke-dasharray="295.3" stroke-dashoffset="295.3"></circle>
        </svg>
        <div class="ring-center">
          <div class="big" id="done-count">0<span style="font-size:14px; color:var(--muted);">/30</span></div>
          <div class="small">DAYS</div>
        </div>
      </div>
      <div class="hero-stats">
        <div class="stat"><span class="k">連続日数</span><span class="v" id="streak">0<span class="unit">日</span></span></div>
        <div class="stat"><span class="k">積み上げ時間</span><span class="v" id="hours">0<span class="unit">時間</span></span></div>
        <div class="stat"><span class="k">現在の週</span><span class="v" id="cur-week">Week 1</span></div>
      </div>
    </div>

    <!-- Complete banner (hidden until all 30 done) -->
    <div class="complete-banner hidden" id="complete-banner">
      <div class="big">30日完走！</div>
      <p>15時間の積み上げ、お疲れさまでした。次は<a href="../income-guide.html">稼ぎ方 完全ガイド</a>でルートを決めて、<a href="../phase1-basics.html">フェーズ1</a>の残りへ。</p>
    </div>

    <!-- Today -->
    <div class="today" id="today-card">
      <span class="today-eyebrow" id="today-eyebrow">TODAY / DAY 1</span>
      <div class="today-week" id="today-week"></div>
      <div class="today-title" id="today-title"></div>
      <div class="today-desc" id="today-desc"></div>

      <div class="timer" id="timer">
        <div class="timer-digits" id="timer-digits">30:00</div>
        <div class="timer-track"><div class="timer-fill" id="timer-fill"></div></div>
        <div class="timer-msg" id="timer-msg">タイマーを開始して30分だけ集中する</div>
        <div class="timer-btns">
          <button class="btn-ghost" id="timer-toggle" type="button">スタート</button>
          <button class="btn-ghost" id="timer-reset" type="button">リセット</button>
        </div>
      </div>

      <button class="btn-primary" id="done-btn" type="button">今日の分を完了にする</button>

      <div class="note-field">
        <label for="today-note">今日のメモ（学んだこと・つまずき）</label>
        <textarea id="today-note" placeholder="例: Flexboxのjustify-contentとalign-itemsの違いがわかった"></textarea>
      </div>
    </div>

    <!-- Map -->
    <div class="map-card">
      <div class="map-head">
        <h2>30日マップ</h2>
        <span class="hint">タップで各日の詳細</span>
      </div>
      <div class="map-grid" id="map-grid"></div>
      <div class="map-legend">
        <span><i class="lg done"></i>完了</span>
        <span><i class="lg current"></i>今日</span>
        <span><i class="lg todo"></i>未着手</span>
      </div>
    </div>

    <!-- Selected day detail -->
    <div class="detail hidden" id="detail">
      <div class="status" id="detail-status"></div>
      <div class="today-week" id="detail-week"></div>
      <div class="today-title" id="detail-title"></div>
      <div class="today-desc" id="detail-desc"></div>
      <div class="note-field">
        <label for="detail-note">この日のメモ</label>
        <textarea id="detail-note"></textarea>
      </div>
      <div class="btn-row">
        <button class="btn-ghost" id="detail-toggle" type="button">完了にする</button>
      </div>
    </div>

    <!-- Weeks -->
    <div class="weeks">
      <h2>週ごとのテーマ</h2>
      <div id="week-rows"></div>
    </div>

    <div class="app-foot">
      <a href="../thirty-day-plan.html">プランの解説ページ →</a>
      <button class="btn-danger-ghost" id="reset-all" type="button">全データをリセット</button>
    </div>
  </div>

  <script>
    (function () {
      'use strict';

      var STORAGE_KEY = 'engineer-30day-app-v1';
      var TIMER_SECONDS = 30 * 60;
      var RING_CIRCUMFERENCE = 295.3;

      var WEEKS = [
        { label: 'Week 1', theme: 'HTMLに触れる' },
        { label: 'Week 2', theme: 'CSSで見た目を作る' },
        { label: 'Week 3', theme: 'ページを完成させて公開する' },
        { label: 'Week 4', theme: 'JavaScriptの味見と、次の一手' }
      ];

      // w: week index (0-3)
      var TASKS = [
        { w: 0, t: 'Progateに登録して、HTML & CSS 初級編を始める', d: '見出し・段落・リンクまで。今日はアカウント作成と最初のレッスンだけでOK。' },
        { w: 0, t: '画像・リストのタグを学ぶ', d: 'img・ul/ol/li。Progateの続きを30分進める。' },
        { w: 0, t: 'フォームとボタンのタグを学ぶ', d: 'input・button・form。「見たことある部品」がタグで書けることを実感する。' },
        { w: 0, t: 'HTML & CSS 初級編のHTMLパートを終える', d: '終わらなければ翌日に持ち越してOK。進捗より継続が優先。' },
        { w: 0, t: 'VS CodeとChromeを準備して、hello.htmlを作る', d: 'ローカルにファイルを作り、ブラウザで開く。教材の外で動かす最初の一歩。' },
        { w: 0, t: '自己紹介ページの骨組みをHTMLだけで書く', d: '名前・趣味・好きなもの3つ。見た目は気にしない。構造だけ。' },
        { w: 0, t: '週の復習 — わからなかったタグをMDNで3つ調べる', d: '「調べて解決する」練習。エンジニアの仕事の半分はこれ。' },
        { w: 1, t: 'CSSの基本 — セレクタ・色・フォント', d: 'ProgateのCSSパートへ。HTMLに色がつく瞬間を体験する。' },
        { w: 1, t: 'ボックスモデルを理解する', d: 'margin・padding・border。CSSで最初につまずく場所なので30分まるごと使う。' },
        { w: 1, t: 'Flexboxで横並びを作る', d: 'display: flex。現代のレイアウトの主役。' },
        { w: 1, t: 'Flexbox Froggyで遊びながら定着させる', d: '無料のブラウザゲーム。24面クリアを目指す（終わらなくてOK）。' },
        { w: 1, t: '自己紹介ページにCSSを当てる', d: '背景色・文字色・余白。DAY 6の骨組みに見た目をつける。' },
        { w: 1, t: 'ヘッダーとカード風レイアウトを作る', d: '上部にタイトルバー、コンテンツを白いカードに。Flexboxを実戦投入。' },
        { w: 1, t: '週の復習 — 好きなサイトを観察して1ブロック真似る', d: '「このボタンはどう作られている？」と右クリック→検証で覗いてみる。' },
        { w: 2, t: 'フォントと配色を決めて適用する', d: 'Google Fontsから1書体、色は3色まで（背景・文字・アクセント）。' },
        { w: 2, t: 'メディアクエリの基本を学ぶ', d: '@media (max-width: 600px)。画面幅で見た目を変える仕組み。' },
        { w: 2, t: '自己紹介ページをスマホ対応にする', d: 'Chromeの検証モードでスマホ表示を確認しながら調整。' },
        { w: 2, t: 'GitHubアカウントとリポジトリを作る', d: 'アカウント作成 → 「my-profile」リポジトリ作成 → ファイルをアップロード。' },
        { w: 2, t: 'GitHub Pagesで公開する', d: 'Settings → Pages → 公開。自分のページがURL付きでネット上に存在する日。' },
        { w: 2, t: '公開ページをスマホの実機で見て微調整する', d: '文字が小さい・はみ出す等を直して再アップロード。' },
        { w: 2, t: '週の復習 — 公開URLを1人に見せて感想を1つもらう', d: '「人に見せる」心理的ハードルを最小サイズで越えておく。' },
        { w: 3, t: 'JavaScript初級を始める — 変数と計算', d: 'ProgateのJavaScriptコースへ。「動きを作る言語」の最初の一歩。' },
        { w: 3, t: '条件分岐（if / else）', d: '「もし〜なら」をコードで書く。プログラミングの本体に触れる。' },
        { w: 3, t: '関数', d: '処理に名前をつけて使い回す仕組み。' },
        { w: 3, t: '配列とループ', d: '複数のデータをまとめて処理する。ここまでがJSの基礎4点セット。' },
        { w: 3, t: 'DOM操作の初歩 — ボタンで文字を変える', d: 'HTMLの要素をJSから書き換える。Webページが「動く」原理。' },
        { w: 3, t: '自己紹介ページに「動く要素」を1つ足す', d: 'ボタンで挨拶が切り替わる、ダークモード切替など。小さくてOK。' },
        { w: 3, t: '総復習 — できたこと・わからないことを書き出す', d: '箇条書きでOK。この記録が次の計画の材料になる。' },
        { w: 3, t: '「稼ぎ方 完全ガイド」を読んで目標ルートを決める', d: '正社員・副業・フリーランス。どこを目指すかで次の学習内容が変わる。' },
        { w: 3, t: '次の30日の計画を立てる', d: '時間を増やして本格参入するか、30分継続か。ここまで来たら適性は十分ある。' }
      ];

      // ── State ──
      function load() {
        try {
          var raw = JSON.parse(localStorage.getItem(STORAGE_KEY));
          if (raw && typeof raw === 'object' && raw.days) return raw;
        } catch (e) { /* fall through */ }
        return { days: {} };
      }
      function save() { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }

      var state = load();
      var selectedDay = null; // 1-based day shown in detail panel, or null

      function dayData(n) { return state.days[n] || {}; }
      function isDone(n) { return !!dayData(n).done; }
      function setDay(n, patch) {
        var cur = state.days[n] || {};
        for (var k in patch) cur[k] = patch[k];
        state.days[n] = cur;
        save();
      }

      function currentDay() {
        for (var i = 1; i <= 30; i++) { if (!isDone(i)) return i; }
        return null; // all complete
      }
      function doneCount() {
        var c = 0;
        for (var i = 1; i <= 30; i++) { if (isDone(i)) c++; }
        return c;
      }

      function localDateStr(d) {
        return d.getFullYear() + '-' +
          String(d.getMonth() + 1).padStart(2, '0') + '-' +
          String(d.getDate()).padStart(2, '0');
      }
      function streak() {
        var dates = {};
        for (var i = 1; i <= 30; i++) {
          var da = dayData(i);
          if (da.done && da.doneAt) dates[da.doneAt] = true;
        }
        var count = 0;
        var cursor = new Date();
        // streak counts through yesterday if today's session isn't done yet
        if (!dates[localDateStr(cursor)]) cursor.setDate(cursor.getDate() - 1);
        while (dates[localDateStr(cursor)]) {
          count++;
          cursor.setDate(cursor.getDate() - 1);
        }
        return count;
      }

      // ── Elements ──
      var $ = function (id) { return document.getElementById(id); };
      var ring = $('ring');
      var mapGrid = $('map-grid');
      var weekRows = $('week-rows');

      // Build map cells once
      var cells = [];
      for (var i = 1; i <= 30; i++) {
        (function (n) {
          var b = document.createElement('button');
          b.type = 'button';
          b.className = 'cell';
          b.textContent = n;
          b.setAttribute('aria-label', 'DAY ' + n + ': ' + TASKS[n - 1].t);
          b.addEventListener('click', function () {
            selectedDay = (selectedDay === n) ? null : n;
            render();
            if (selectedDay) $('detail').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          });
          mapGrid.appendChild(b);
          cells.push(b);
        })(i);
      }

      // ── Render ──
      function render() {
        var done = doneCount();
        var cur = currentDay();

        // hero
        $('done-count').innerHTML = done + '<span style="font-size:14px; color:var(--muted);">/30</span>';
        ring.style.strokeDashoffset = String(RING_CIRCUMFERENCE * (1 - done / 30));
        $('streak').innerHTML = streak() + '<span class="unit">日</span>';
        $('hours').innerHTML = (Math.round(done * 0.5 * 10) / 10) + '<span class="unit">時間</span>';
        $('cur-week').textContent = cur ? WEEKS[TASKS[cur - 1].w].label : '完走';

        // today card / complete banner
        if (cur === null) {
          $('complete-banner').classList.remove('hidden');
          $('today-card').classList.add('hidden');
        } else {
          $('complete-banner').classList.add('hidden');
          $('today-card').classList.remove('hidden');
          var task = TASKS[cur - 1];
          $('today-eyebrow').textContent = 'TODAY / DAY ' + cur;
          $('today-week').textContent = WEEKS[task.w].label + ' — ' + WEEKS[task.w].theme;
          $('today-title').textContent = task.t;
          $('today-desc').textContent = task.d;
          var note = $('today-note');
          if (note.dataset.day !== String(cur)) {
            note.dataset.day = String(cur);
            note.value = dayData(cur).note || '';
          }
        }

        // map
        cells.forEach(function (cell, idx) {
          var n = idx + 1;
          cell.classList.toggle('done', isDone(n));
          cell.classList.toggle('current', cur === n);
          cell.classList.toggle('selected', selectedDay === n);
        });

        // detail
        if (selectedDay) {
          $('detail').classList.remove('hidden');
          var t = TASKS[selectedDay - 1];
          var d = dayData(selectedDay);
          var st = $('detail-status');
          st.textContent = 'DAY ' + selectedDay + ' — ' + (d.done ? '完了' + (d.doneAt ? '（' + d.doneAt + '）' : '') : '未完了');
          st.className = 'status ' + (d.done ? 'is-done' : 'is-todo');
          $('detail-week').textContent = WEEKS[t.w].label + ' — ' + WEEKS[t.w].theme;
          $('detail-title').textContent = t.t;
          $('detail-desc').textContent = t.d;
          $('detail-toggle').textContent = d.done ? '未完了に戻す' : '完了にする';
          var dnote = $('detail-note');
          if (dnote.dataset.day !== String(selectedDay)) {
            dnote.dataset.day = String(selectedDay);
            dnote.value = d.note || '';
          }
        } else {
          $('detail').classList.add('hidden');
          $('detail-note').dataset.day = '';
        }

        // weeks overview
        weekRows.innerHTML = '';
        WEEKS.forEach(function (w, wi) {
          var total = 0, wd = 0;
          TASKS.forEach(function (t, ti) {
            if (t.w === wi) { total++; if (isDone(ti + 1)) wd++; }
          });
          var row = document.createElement('div');
          row.className = 'week-row';
          var left = document.createElement('div');
          left.className = 'wl';
          var wn = document.createElement('span');
          wn.className = 'wn';
          wn.textContent = w.label;
          left.appendChild(wn);
          left.appendChild(document.createTextNode(w.theme));
          var right = document.createElement('span');
          right.className = 'wc';
          right.textContent = wd + '/' + total;
          row.appendChild(left);
          row.appendChild(right);
          weekRows.appendChild(row);
        });
      }

      // ── Actions ──
      $('done-btn').addEventListener('click', function () {
        var cur = currentDay();
        if (cur === null) return;
        setDay(cur, { done: true, doneAt: localDateStr(new Date()) });
        resetTimer();
        render();
      });

      $('today-note').addEventListener('input', function () {
        var day = Number(this.dataset.day);
        if (day) setDay(day, { note: this.value });
      });

      $('detail-note').addEventListener('input', function () {
        var day = Number(this.dataset.day);
        if (day) setDay(day, { note: this.value });
      });

      $('detail-toggle').addEventListener('click', function () {
        if (!selectedDay) return;
        var d = dayData(selectedDay);
        if (d.done) {
          setDay(selectedDay, { done: false, doneAt: null });
        } else {
          setDay(selectedDay, { done: true, doneAt: localDateStr(new Date()) });
        }
        render();
      });

      $('reset-all').addEventListener('click', function () {
        if (!confirm('30日分の進捗とメモをすべて削除します。よろしいですか？')) return;
        state = { days: {} };
        save();
        selectedDay = null;
        resetTimer();
        render();
      });

      // ── Timer ──
      var remaining = TIMER_SECONDS;
      var ticking = null;

      function fmt(sec) {
        var m = Math.floor(sec / 60);
        var s = sec % 60;
        return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
      }
      function renderTimer() {
        $('timer-digits').textContent = fmt(remaining);
        $('timer-fill').style.width = ((TIMER_SECONDS - remaining) / TIMER_SECONDS * 100) + '%';
        document.title = ticking ? fmt(remaining) + ' — 30×30' : '30×30 — 1日30分×30日';
      }
      function stopTicking() {
        if (ticking) { clearInterval(ticking); ticking = null; }
        $('timer').classList.remove('running');
        $('timer-toggle').textContent = remaining === TIMER_SECONDS ? 'スタート' : '再開';
      }
      function resetTimer() {
        stopTicking();
        remaining = TIMER_SECONDS;
        $('timer').classList.remove('finished');
        $('timer-msg').textContent = 'タイマーを開始して30分だけ集中する';
        $('timer-toggle').textContent = 'スタート';
        $('timer-toggle').disabled = false;
        renderTimer();
      }
      function finishTimer() {
        stopTicking();
        $('timer').classList.add('finished');
        $('timer-msg').textContent = '30分お疲れさまでした。ここで強制終了 — 完了ボタンへ！';
        $('timer-toggle').disabled = true;
        if (navigator.vibrate) navigator.vibrate([200, 100, 200]);
        renderTimer();
      }

      $('timer-toggle').addEventListener('click', function () {
        if (ticking) { stopTicking(); renderTimer(); return; }
        if (remaining <= 0) return;
        $('timer').classList.add('running');
        $('timer-toggle').textContent = '一時停止';
        $('timer-msg').textContent = '集中タイム — 乗ってきても30分で止めるのがコツ';
        var lastTick = Date.now();
        ticking = setInterval(function () {
          var now = Date.now();
          var elapsed = Math.round((now - lastTick) / 1000);
          if (elapsed >= 1) {
            remaining = Math.max(0, remaining - elapsed);
            lastTick = now;
            renderTimer();
            if (remaining <= 0) finishTimer();
          }
        }, 250);
      });

      $('timer-reset').addEventListener('click', resetTimer);

      // ── Init ──
      renderTimer();
      render();
    })();
  </script>
</body>
</html>

