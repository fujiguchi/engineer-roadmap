    .proscons-col.pros li::before { content: '+'; color: #1a8a5a; }
    .proscons-col.cons li::before { content: '−'; color: #b5432f; }

    /* Stat box */
    .stat-box { background: var(--navy); color: #fff; border-radius: 10px; padding: 18px 22px; text-align: center; margin-bottom: 14px; }
    .stat-box .num { font-size: 34px; font-weight: 800; color: var(--accent-soft); }
    .stat-box .label { font-size: 13px; margin-top: 4px; }
    .stat-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin-bottom: 14px; }

    /* Summary list */
    .summary-list { counter-reset: s; list-style: none; padding: 0; }
    .summary-list li { counter-increment: s; background: #fff; border-radius: 10px; padding: 14px 18px 14px 50px; margin-bottom: 10px; position: relative; border: 1px solid rgba(30,39,97,0.08); font-size: 14px; line-height: 1.6; }
    .summary-list li::before { content: counter(s); position: absolute; left: 14px; top: 14px; width: 24px; height: 24px; border-radius: 50%; background: var(--accent); color: #fff; font-weight: 800; font-size: 13px; display: flex; align-items: center; justify-content: center; }

    /* Footer nav */
    .page-nav { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px; margin-top: 32px; padding-top: 20px; border-top: 1px solid rgba(30,39,97,0.1); }
    .page-nav a { font-size: 14px; font-weight: 700; color: var(--navy); text-decoration: none; }
    .page-nav a:hover { color: var(--accent); }

    @media (max-width: 600px) {
