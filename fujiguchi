      background: var(--surface); border: 1px solid var(--line);
      border-radius: 16px; padding: 20px; margin-bottom: 14px;
    }
    .today-eyebrow {
      display: inline-block; font-size: 10px; font-weight: 800; letter-spacing: 2px;
