      </div>
    </section>

    <!-- =========================================
         Section: 各ルート詳細
         ========================================= -->
    <section class="block">
      <span class="eyebrow">INCOME PATHS</span>
      <h2>各ルートの詳細</h2>

      <!-- 正社員 -->
      <div class="path-card">
        <h3>正社員 <span class="path-tag tag-easy">参入しやすい</span></h3>
